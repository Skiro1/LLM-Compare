# =============================================================================
# LLM Compare - .gitignore
# =============================================================================

# Archives
*.zip
*.rar
*.7z
*.tar.gz
*.tar.bz2

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Node
node_modules/
package-lock.json
npm-debug.log

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# LibreTranslate (external dependency)
LibreTranslate/

# Logs
*.log

# Temporary files
*.tmp
*.temp
*.bak
nul

# Project-specific (not part of the codebase)
AGENTS.md
Commands.txt
opencode.json

# Translation helper scripts (one-time use)
translate.js
*.translate.*
bulk_translate.*
translate_all.*

# Environment variables
.env
.env.local
.env.*.local

# Build artifacts (if using bundler in future)
dist/
build/
out/
